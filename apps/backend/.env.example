# Integrum V2 - Environment Template
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.

# Security
SECRET_KEY=<generate-with: python -c "import secrets; print(secrets.token_urlsafe(32))">
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
DATABASE_URL=postgresql+asyncpg://integrum_user:integrum_password@localhost:5432/integrum_v2

# API
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_PER_MINUTE=60

# Medical Vault (Fernet key — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
VAULT_MASTER_KEY=<generate-with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">

# Redis (required for account lockout + JWT revocation — SEC-01, SEC-02)
REDIS_URL=redis://localhost:6379/0

# Account lockout config (optional — defaults shown)
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_SECONDS=900

# JWT refresh token
REFRESH_TOKEN_EXPIRE_DAYS=7
